# ── Server ────────────────────────────────────────────────
# HTTP server port (auto-fallback to next port if occupied)
PORT=7890

# ── Logging ───────────────────────────────────────────────
# Log level filter (uses env_logger / tracing-subscriber syntax)
#
# Levels (from most to least verbose):
#   trace → debug → info → warn → error
#
# Examples:
#   RUST_LOG=telegraph_hub_rs=info          # (default) info and above for this crate
#   RUST_LOG=telegraph_hub_rs=debug         # debug output for development
#   RUST_LOG=telegraph_hub_rs=warn          # only warnings and errors
#   RUST_LOG=telegraph_hub_rs=trace         # maximum verbosity (includes all HTTP details)
#   RUST_LOG=info                           # info for ALL crates (including dependencies)
#   RUST_LOG=warn,telegraph_hub_rs=debug    # debug for this crate, warn for dependencies
#
RUST_LOG=telegraph_hub_rs=info

# ── File Logging ──────────────────────────────────────────
# Set to a directory path to enable daily rolling log files.
# Leave commented out or empty to disable file logging (stdout only).
#
# Examples:
#   LOG_DIR=logs             # relative to working directory
#   LOG_DIR=./logs           # same as above
#   LOG_DIR=/var/log/thub    # absolute path
#
# Log files are named: telegraph-hub-rs.log.YYYY-MM-DD
#
# LOG_DIR=logs

# ── Log Timezone ──────────────────────────────────────────
# Timezone for log timestamps. Only effective when LOG_DIR is set.
# If omitted, defaults to system local timezone.
#
# Examples:
#   LOG_TZ=local             # system local timezone (default)
#   LOG_TZ=UTC               # UTC+0
#   LOG_TZ=+8                # UTC+8 (e.g. Asia/Taipei, Asia/Shanghai)
#   LOG_TZ=+09:00            # UTC+9 (e.g. Asia/Tokyo)
#   LOG_TZ=-5                # UTC-5 (e.g. US Eastern)
#   LOG_TZ=+05:30            # UTC+5:30 (e.g. Asia/Kolkata)
#   LOG_TZ=UTC+8             # same as +8
#
# LOG_TZ=+8

# ── Cache Database ────────────────────────────────────────
# SQLite database path for page cache persistence across restarts.
# Falls back to in-memory cache if the file cannot be opened.
TELEGRAPH_HUB_DB=telegraph_hub_cache.db
